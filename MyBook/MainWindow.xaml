<Window x:Class="MyBook.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyBook"
        mc:Ignorable="d"
        Title="MyBook" Height="760" Width="1180" MinHeight="620" MinWidth="920"
        Icon="Assets/AppIcon.ico"
        Background="#F5F7FA"
        FontFamily="Microsoft YaHei UI, Segoe UI">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
        <Style x:Key="SelectableText" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FilterComboBox" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Foreground" Value="#334155"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root"
                                Margin="0,0,8,0"
                                Padding="{TemplateBinding Padding}"
                                Background="#E2E8F0"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0F766E"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#0F766E"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Width="420" VerticalAlignment="Top" Margin="18,4,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding SelectedAssetDateText}" FontSize="12" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding SnapshotTimeText}" FontSize="12" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Width="70" Height="30"
                            Background="#0F766E"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="12"
                            Content="刷新"
                            Click="Refresh_Click"/>
                </StackPanel>
                <Slider Minimum="0"
                        Maximum="{Binding AssetSummaryMaximum}"
                        Value="{Binding SelectedAssetSummaryOffset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Ticks="{Binding AssetSummaryTicks}"
                        TickPlacement="BottomRight"
                        IsSnapToTickEnabled="True"
                        IsMoveToPointEnabled="True"
                        Margin="0,8,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                <TextBox Style="{StaticResource SelectableText}"
                         Text="{Binding TotalAssets.ValueText}"
                         FontSize="44"
                         FontWeight="SemiBold"
                         Foreground="#047857"/>
                <TextBox Style="{StaticResource SelectableText}"
                         Text="{Binding TotalAssets.ExactText}"
                         FontSize="13"
                         Foreground="#64748B"
                         Margin="12,21,0,0"/>
            </StackPanel>
        </DockPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,14" Grid.IsSharedSizeScope="True">
            <ItemsControl ItemsSource="{Binding CurrencySummaries}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="CurrencyNet"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="CurrencyExact"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="CurrencyAssets"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="CurrencySeparator"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="CurrencyLiabilities"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Style="{StaticResource SelectableText}"
                                     Grid.Column="0"
                                     Text="{Binding NetLineText}"
                                     FontSize="17"
                                     FontWeight="SemiBold"
                                     Foreground="#0F172A"
                                     TextAlignment="Right"/>
                            <TextBox Style="{StaticResource SelectableText}"
                                     Grid.Column="1"
                                     Text="{Binding NetExactText}"
                                     FontSize="11"
                                     Foreground="#64748B"
                                     Margin="12,4,0,0"
                                     TextAlignment="Right"/>
                            <TextBox Style="{StaticResource SelectableText}"
                                     Grid.Column="2"
                                     Text="{Binding AssetsText}"
                                     FontSize="13"
                                     FontWeight="SemiBold"
                                     Foreground="#334155"
                                     Margin="18,2,0,0"
                                     TextAlignment="Right"/>
                            <TextBlock Grid.Column="3"
                                       Text="{Binding BreakdownSeparatorText}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#64748B"
                                       Margin="8,2,8,0"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                            <TextBox Style="{StaticResource SelectableText}"
                                     Grid.Column="4"
                                     Text="{Binding LiabilitiesText}"
                                     FontSize="13"
                                     FontWeight="SemiBold"
                                     Foreground="#334155"
                                     Margin="0,2,0,0"
                                     TextAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <TabControl Grid.Row="2">
            <TabItem Header="12个月收支">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,16,0,10">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox Content="单币种"
                                      IsChecked="{Binding ShowSingleCurrencyMonthly, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      FontSize="13"
                                      Foreground="#334155"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0"/>
                            <ComboBox Style="{StaticResource FilterComboBox}"
                                      ItemsSource="{Binding MonthlyAccounts}"
                                      SelectedItem="{Binding SelectedMonthlyAccount, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName"
                                      MinWidth="180"
                                      Height="32"/>
                        </StackPanel>
                        <TextBlock Text="过去12个月" FontSize="15" FontWeight="SemiBold" Foreground="#334155"/>
                    </DockPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding VisibleMonthlySeries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="190"/>
                                                <RowDefinition Height="190"/>
                                            </Grid.RowDefinitions>
                                            <DockPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A"/>
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                    <TextBox Style="{StaticResource SelectableText}" Text="{Binding TotalIncomeText}" FontSize="13" Foreground="#047857" Margin="0,0,16,0"/>
                                                    <TextBox Style="{StaticResource SelectableText}" Text="{Binding TotalExpenseText}" FontSize="13" Foreground="#BE123C" Margin="0,0,16,0"/>
                                                    <TextBox Style="{StaticResource SelectableText}" Text="{Binding NetChangeText}" FontSize="13" Foreground="#334155"/>
                                                </StackPanel>
                                            </DockPanel>
                                            <Grid Grid.Row="1" Margin="0,12,0,0">
                                                <TextBlock Text="收" FontSize="12" FontWeight="SemiBold" Foreground="#047857" HorizontalAlignment="Right"/>
                                                <local:MonthlyFlowChart Items="{Binding Points}" FlowKind="Income" Margin="0,14,0,0"/>
                                            </Grid>
                                            <Grid Grid.Row="2" Margin="0,12,0,0">
                                                <TextBlock Text="支" FontSize="12" FontWeight="SemiBold" Foreground="#BE123C" HorizontalAlignment="Right"/>
                                                <local:MonthlyFlowChart Items="{Binding Points}" FlowKind="Expense" Margin="0,14,0,0"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="账户资金">
                <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="账户整体资金净出入" FontSize="15" FontWeight="SemiBold" Foreground="#334155"/>
                        </DockPanel>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding AccountNetFlows}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  SelectionUnit="CellOrRowHeader">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="账户整体" Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Style="{StaticResource SelectableText}"
                                                     Text="{Binding DisplayName}"
                                                     FontSize="13"
                                                     Foreground="#334155"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="净流动" Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding NetRmbText}"
                                                     FontSize="13"
                                                     FontWeight="SemiBold">
                                                <TextBox.Style>
                                                    <Style BasedOn="{StaticResource SelectableText}" TargetType="TextBox">
                                                        <Setter Property="Foreground" Value="#334155"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsInflow}" Value="True">
                                                                <Setter Property="Foreground" Value="#047857"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsOutflow}" Value="True">
                                                                <Setter Property="Foreground" Value="#BE123C"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="当前余额" Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Style="{StaticResource SelectableText}"
                                                     Text="{Binding CurrentBalanceText}"
                                                     FontSize="13"
                                                     TextAlignment="Right"
                                                     Foreground="#334155"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="原币净额" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Style="{StaticResource SelectableText}"
                                                     Text="{Binding CurrencyDetails}"
                                                     FontSize="13"
                                                     Foreground="#64748B"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="月度支出">
                <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel>
                            <TextBox DockPanel.Dock="Right" Style="{StaticResource SelectableText}" Text="{Binding SelectedReasonSeries.TotalFlowText}" FontSize="13" Foreground="#334155"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SelectedReasonMonthLabel}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#334155"
                                           VerticalAlignment="Center"/>
                                <Slider Width="260"
                                        Minimum="0"
                                        Maximum="{Binding ReasonMonthMaximum}"
                                        Value="{Binding SelectedReasonMonthIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        TickFrequency="1"
                                        TickPlacement="BottomRight"
                                        IsSnapToTickEnabled="True"
                                        IsMoveToPointEnabled="True"
                                        Margin="16,0,0,0"
                                        Height="30"
                                        VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                            <ItemsControl ItemsSource="{Binding SelectedReasonSeries.Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="44">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="158"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="210"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding KindText}" FontSize="12" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#BE123C"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsIncome}" Value="True">
                                                                <Setter Property="Foreground" Value="#047857"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" Text="{Binding Reason}" FontSize="12" Foreground="#334155" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <ProgressBar Grid.Column="2" Value="{Binding BarPercent}" Maximum="100" Height="7" VerticalAlignment="Center" Background="#F1F5F9" BorderThickness="0">
                                                <ProgressBar.Style>
                                                    <Style TargetType="ProgressBar">
                                                        <Setter Property="Foreground" Value="#BE123C"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsIncome}" Value="True">
                                                                <Setter Property="Foreground" Value="#047857"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ProgressBar.Style>
                                            </ProgressBar>
                                            <StackPanel Grid.Column="3" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBox Text="{Binding TotalText}" FontSize="12">
                                                    <TextBox.Style>
                                                        <Style BasedOn="{StaticResource SelectableText}" TargetType="TextBox">
                                                            <Setter Property="Foreground" Value="#BE123C"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsIncome}" Value="True">
                                                                    <Setter Property="Foreground" Value="#047857"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                                <TextBox Style="{StaticResource SelectableText}" Text="{Binding CurrencyDetails}" FontSize="10" Foreground="#94A3B8"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="投资统计">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <RadioButton Content="按原因"
                                         GroupName="InvestmentMode"
                                         IsChecked="{Binding ShowInvestmentByReason, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13"
                                         Foreground="#334155"
                                         Margin="0,0,18,0"/>
                            <RadioButton Content="按股票"
                                         GroupName="InvestmentMode"
                                         IsChecked="{Binding ShowInvestmentByHolding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13"
                                         Foreground="#334155"/>
                        </StackPanel>
                        <ComboBox Grid.Column="2"
                                  Style="{StaticResource FilterComboBox}"
                                  ItemsSource="{Binding InvestmentAccounts}"
                                  SelectedItem="{Binding SelectedInvestmentAccount, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  MinWidth="180"
                                  Height="32"/>
                    </Grid>
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding VisibleInvestmentPeriods}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" Foreground="#334155"/>
                                        <DataGrid Grid.Row="1"
                                                  ItemsSource="{Binding Items}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  CanUserAddRows="False"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="None"
                                                  SelectionUnit="CellOrRowHeader"
                                                  Margin="0,12,0,0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="项目" Binding="{Binding Name}" Width="*"/>
                                                <DataGridTextColumn Header="收入" Binding="{Binding TotalText}" Width="Auto"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="0,8,0,0" Margin="0,8,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="总计" FontSize="13" FontWeight="SemiBold" Foreground="#334155"/>
                                                <TextBox Grid.Column="1"
                                                         Style="{StaticResource SelectableText}"
                                                         Text="{Binding TotalText}"
                                                         FontSize="13"
                                                         FontWeight="SemiBold"
                                                         Foreground="#047857"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </TabItem>

            <TabItem Header="详情">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding DetailStatusText}"
                                   FontSize="12"
                                   Foreground="#64748B"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="时间"
                                       FontSize="13"
                                       Foreground="#334155"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <DatePicker SelectedDate="{Binding DetailStartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="128"
                                        Height="30"
                                        FontSize="13"
                                        SelectedDateChanged="DetailDate_SelectedDateChanged"/>
                            <TextBlock Text="-"
                                       FontSize="13"
                                       Foreground="#64748B"
                                       VerticalAlignment="Center"
                                       Margin="8,0"/>
                            <DatePicker SelectedDate="{Binding DetailEndDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        DisplayDateStart="{Binding DetailStartDate}"
                                        Width="128"
                                        Height="30"
                                        FontSize="13"
                                        SelectedDateChanged="DetailDate_SelectedDateChanged"/>
                            <TextBlock Text="账户"
                                       FontSize="13"
                                       Foreground="#334155"
                                       VerticalAlignment="Center"
                                       Margin="16,0,8,0"/>
                            <ComboBox ItemsSource="{Binding DetailAccountNames}"
                                      Style="{StaticResource FilterComboBox}"
                                      SelectedItem="{Binding SelectedDetailAccountName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectionChanged="DetailAccount_SelectionChanged"
                                      Width="168"
                                      Height="32"/>
                            <Button Content="新增"
                                    Width="66"
                                    Height="30"
                                    Margin="12,0,0,0"
                                    Click="AddRecordDetail_Click"/>
                            <Button Content="放弃"
                                    Width="66"
                                    Height="30"
                                    Margin="8,0,0,0"
                                    Click="DiscardRecordDetails_Click"/>
                            <Button Content="保存"
                                    Width="66"
                                    Height="30"
                                    Margin="8,0,0,0"
                                    Background="#0F766E"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Click="SaveRecordDetails_Click"/>
                        </StackPanel>
                    </DockPanel>
                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            Padding="8"
                            Margin="0,0,0,10">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Left"
                                       Text="余额"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#334155"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding DetailAccountBalances}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,14,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="116"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Currency}"
                                                           FontSize="12"
                                                           Foreground="#64748B"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0"/>
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=0.############}"
                                                         Height="26"
                                                         Padding="6,2"
                                                         FontSize="12"
                                                         BorderBrush="#CBD5E1"
                                                         Background="White"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                    <DataGrid x:Name="RecordDetailsGrid"
                              Grid.Row="2"
                              ItemsSource="{Binding RecordDetails}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              SelectionUnit="CellOrRowHeader"
                              AlternatingRowBackground="#F8FAFC"
                              RowBackground="White"
                              BorderBrush="#E2E8F0"
                              BorderThickness="1"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="58" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="日期" Width="136">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Date, StringFormat=yyyy-MM-dd HH:mm}" Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Date, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=yyyy-MM-dd HH:mm}"
                                                 IsReadOnly="{Binding IsDateReadOnly}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="账户" Binding="{Binding AccountName}" Width="150" IsReadOnly="True"/>
                            <DataGridTextColumn Header="金额" Binding="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=0.##}" Width="96"/>
                            <DataGridTemplateColumn Header="币种" Width="82">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Currency}" Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox Style="{StaticResource FilterComboBox}"
                                                  ItemsSource="{Binding DataContext.DetailCurrencyTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding Currency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding IsCurrencyEditable}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="原因" Binding="{Binding Reason, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                            <DataGridTextColumn Header="对方" Binding="{Binding DestAccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="220"/>
                            <DataGridTemplateColumn Header="数量" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding HoldingQuantity}" Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding HoldingQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 IsReadOnly="{Binding IsHoldingQuantityReadOnly}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridCheckBoxColumn Header="内部" Binding="{Binding IsInternal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="62"/>
                            <DataGridTextColumn Header="匹配" Binding="{Binding MatchedRecordId}" Width="70" IsReadOnly="True"/>
                            <DataGridTextColumn Header="匹配原因" Binding="{Binding MatchedRecordReason}" Width="140" IsReadOnly="True"/>
                            <DataGridCheckBoxColumn Header="已抵消" Binding="{Binding IsRefundMatched, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="74"/>
                            <DataGridTextColumn Header="均摊天数" Binding="{Binding ExpenseAllocationDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" Width="86"/>
                            <DataGridTextColumn Header="来源" Binding="{Binding Source, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="220"/>
                            <DataGridTextColumn Header="导入" Binding="{Binding StatementProviderText}" Width="126" IsReadOnly="True"/>
                            <DataGridTextColumn Header="键" Binding="{Binding StatementKey}" Width="130" IsReadOnly="True"/>
                            <DataGridCheckBoxColumn Header="备份" Binding="{Binding HasBackup}" Width="62" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

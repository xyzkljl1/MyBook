<Window x:Class="MyBook.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyBook"
        mc:Ignorable="d"
        Title="MyBook" Height="760" Width="1180" MinHeight="620" MinWidth="920"
        Background="#F5F7FA"
        FontFamily="Microsoft YaHei UI, Segoe UI">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root"
                                Margin="0,0,8,0"
                                Padding="{TemplateBinding Padding}"
                                Background="#E2E8F0"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0F766E"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#0F766E"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,18">
            <Button DockPanel.Dock="Right"
                    Width="86" Height="34"
                    Background="#0F766E"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="13"
                    Content="刷新"
                    Click="Refresh_Click"/>
            <TextBlock Text="{Binding SnapshotTimeText}" FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
        </DockPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,18">
            <Border Style="{StaticResource Card}" Padding="22" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#ECFDF5" CornerRadius="7" Padding="14,7">
                        <TextBlock Text="{Binding TotalAssets.ValueText}"
                                   FontSize="32"
                                   FontWeight="SemiBold"
                                   Foreground="#047857"/>
                    </Border>
                    <TextBlock Text="{Binding TotalAssets.ExactText}"
                               FontSize="13"
                               Foreground="#64748B"
                               Margin="12,13,0,0"/>
                </StackPanel>
            </Border>
            <ItemsControl ItemsSource="{Binding CurrencySummaries}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Width="258" Margin="0,0,12,12">
                            <StackPanel>
                                <TextBlock Text="{Binding Currency}" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <TextBlock Text="{Binding NetText}" FontSize="27" FontWeight="SemiBold" Foreground="#0F172A"/>
                                    <TextBlock Text="{Binding NetExactText}" FontSize="11" Foreground="#64748B" Margin="8,10,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,14,0,0">
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AssetsText}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="{Binding AssetsText}" FontSize="15" Foreground="#047857"/>
                                            <TextBlock Text="{Binding AssetsExactText}" FontSize="10" Foreground="#94A3B8" Margin="5,3,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,5,0,0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LiabilitiesText}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="{Binding LiabilitiesText}" FontSize="15" Foreground="#BE123C"/>
                                            <TextBlock Text="{Binding LiabilitiesExactText}" FontSize="10" Foreground="#94A3B8" Margin="5,3,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <TabControl Grid.Row="2">
            <TabItem Header="12个月收支">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,16,0,10">
                        <CheckBox DockPanel.Dock="Right"
                                  Content="单币种"
                                  IsChecked="{Binding ShowSingleCurrencyMonthly, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  FontSize="13"
                                  Foreground="#334155"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="过去12个月" FontSize="15" FontWeight="SemiBold" Foreground="#334155"/>
                    </DockPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding VisibleMonthlySeries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="230"/>
                                            </Grid.RowDefinitions>
                                            <DockPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A"/>
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding TotalIncomeText}" FontSize="13" Foreground="#047857" Margin="0,0,16,0"/>
                                                    <TextBlock Text="{Binding TotalExpenseText}" FontSize="13" Foreground="#BE123C" Margin="0,0,16,0"/>
                                                    <TextBlock Text="{Binding NetChangeText}" FontSize="13" Foreground="#334155"/>
                                                </StackPanel>
                                            </DockPanel>
                                            <local:MonthlyFlowChart Grid.Row="1" Items="{Binding Points}" Margin="0,12,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="{Binding LastMonthTabHeader}">
                <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <TextBlock Text="{Binding ReasonRmbSeries.TotalIncomeText}" FontSize="13" Foreground="#047857" Margin="0,0,16,0"/>
                                <TextBlock Text="{Binding ReasonRmbSeries.TotalExpenseText}" FontSize="13" Foreground="#BE123C"/>
                            </StackPanel>
                        </DockPanel>
                        <local:ReasonFlowChart Grid.Row="1" Items="{Binding ReasonRmbSeries.Items}" MinHeight="280" Margin="0,12,0,0"/>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
